      "get": {
        "summary": "App Delete",
        "operationId": "app_delete_del_get",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Id"
            }
          }
